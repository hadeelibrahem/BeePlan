PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/beeplan
DB_SSL=false
JWT_SECRET=replace-with-a-long-random-secret
RESEND_API_KEY=
EMAIL_FROM=BeePlan <onboarding@resend.dev>
FRONTEND_URL=http://127.0.0.1:5173
WEB_APP_URL=http://127.0.0.1:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Google OAuth callback configuration
# Use ONE of the setups below. Google Cloud must contain the same callback URL
# in "Authorized redirect URIs".
# Priority used by the app:
# 1. GOOGLE_CALLBACK_URL
# 2. GOOGLE_REDIRECT_URI
# 3. PUBLIC_BASE_URL + /auth/google/callback
# 4. API_PUBLIC_URL + /auth/google/callback
# 5. http://127.0.0.1:3000/auth/google/callback
# ---------------------------------------------------------------------------

# Local Web development
PUBLIC_BASE_URL=http://127.0.0.1:3000
API_PUBLIC_URL=http://127.0.0.1:3000
GOOGLE_CALLBACK_URL=http://127.0.0.1:3000/auth/google/callback
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/auth/google/callback

# Expo Mobile development
# Use a public HTTPS tunnel URL because Google OAuth does not accept private LAN
# callbacks like http://192.168.x.x:3000/auth/google/callback.
# PUBLIC_BASE_URL=https://your-tunnel.ngrok-free.app
# API_PUBLIC_URL=https://your-tunnel.ngrok-free.app
# GOOGLE_CALLBACK_URL=https://your-tunnel.ngrok-free.app/auth/google/callback
# GOOGLE_REDIRECT_URI=https://your-tunnel.ngrok-free.app/auth/google/callback

# Production
# NODE_ENV=production
# PUBLIC_BASE_URL=https://api.your-domain.com
# API_PUBLIC_URL=https://api.your-domain.com
# FRONTEND_URL=https://your-domain.com
# WEB_APP_URL=https://your-domain.com
# GOOGLE_CALLBACK_URL=https://api.your-domain.com/auth/google/callback
# GOOGLE_REDIRECT_URI=https://api.your-domain.com/auth/google/callback
