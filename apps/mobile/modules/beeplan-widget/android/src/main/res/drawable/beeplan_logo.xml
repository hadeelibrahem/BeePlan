<?xml version="1.0" encoding="utf-8"?>
<!--
  BeePlan logo mark — a faithful vector reproduction of the app's BeePlanLogo
  component (apps/mobile/src/components/BeePlanLogo.tsx): a yellow (#fdef4b)
  rounded-square bee body tilted 14°, three dark (#2b323f) stripes, and two
  yellow antenna dots. The "BeePlan" wordmark is rendered next to it by the
  widget header. Local vector only — no raster, no network.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
  android:width="28dp"
  android:height="28dp"
  android:viewportWidth="64"
  android:viewportHeight="64">

  <!-- Body + stripes, tilted like the brand mark -->
  <group android:rotation="14" android:pivotX="32" android:pivotY="37">
    <clip-path
      android:pathData="M22,20 H42 A7,7 0 0 1 49,27 V47 A7,7 0 0 1 42,54 H22 A7,7 0 0 1 15,47 V27 A7,7 0 0 1 22,20 Z" />
    <path android:fillColor="#FDEF4B"
      android:pathData="M22,20 H42 A7,7 0 0 1 49,27 V47 A7,7 0 0 1 42,54 H22 A7,7 0 0 1 15,47 V27 A7,7 0 0 1 22,20 Z" />
    <path android:fillColor="#2B323F" android:pathData="M23.5,27.25 h17 v4.5 h-17 z" />
    <path android:fillColor="#2B323F" android:pathData="M21.5,34.75 h21 v4.5 h-21 z" />
    <path android:fillColor="#2B323F" android:pathData="M20,42.25 h24 v4.5 h-24 z" />
  </group>

  <!-- Antenna dots -->
  <path android:fillColor="#FDEF4B"
    android:pathData="M19.8,12 a2.2,2.2 0 1 0 4.4,0 a2.2,2.2 0 1 0 -4.4,0 z" />
  <path android:fillColor="#FDEF4B"
    android:pathData="M35.8,12 a2.2,2.2 0 1 0 4.4,0 a2.2,2.2 0 1 0 -4.4,0 z" />
</vector>
